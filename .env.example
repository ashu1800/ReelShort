# ReelShort publish-android.py configuration.
# Copy this file to ".env" at the repo root and fill in real values.
# ".env" is gitignored; NEVER commit secrets.

# Tencent COS credentials and bucket for APK hosting.
COS_SECRET_ID=AKID...
COS_SECRET_KEY=...
COS_BUCKET=your-bucket-1234567890
COS_REGION=ap-chengdu

# Backend base URL (no trailing slash) where /api/internal/release/publish is exposed.
RELEASE_BACKEND_URL=https://your-backend.example.com

# Internal super token protecting the publish endpoint (same value deployed to the backend
# via REELSHORT_INTERNAL_SUPER_TOKEN). Must be at least 32 chars with high entropy.
REELSHORT_INTERNAL_SUPER_TOKEN=...

# Expected payout hot-wallet public addresses. Payout signing fails closed when the
# selected network's value is empty or does not match the submitted private key.
REELSHORT_TRON_HOT_WALLET_ADDRESS=T...
REELSHORT_ETH_HOT_WALLET_ADDRESS=0x...

# VIP receipt reconciliation. Payment timestamp must remain within the original order window;
# the grace period only allows delayed chain confirmations to arrive before final expiry.
REELSHORT_VIP_CONFIRMATION_GRACE=10m
REELSHORT_TRON_INCOMING_TRANSFER_MAX_PAGES=50
