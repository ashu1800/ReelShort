# ReelShort publish-android.py configuration.
# Copy this file to ".env" at the repo root and fill in real values.
# ".env" is gitignored; NEVER commit secrets.

# Tencent COS credentials and bucket for APK hosting.
COS_SECRET_ID=AKID...
COS_SECRET_KEY=...
COS_BUCKET=update-1259596907
COS_REGION=ap-chengdu

# Backend base URL (no trailing slash) where /api/internal/release/publish is exposed.
RELEASE_BACKEND_URL=https://shortlink.hjj888.cc

# Internal super token protecting the publish endpoint (same value deployed to the backend
# via REELSHORT_INTERNAL_SUPER_TOKEN).
REELSHORT_INTERNAL_SUPER_TOKEN=...
