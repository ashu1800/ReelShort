# Copy this file to infra/.env before running docker compose.
# Replace every production secret before deployment.

POSTGRES_DB=reelshort
POSTGRES_USER=reelshort
# Required by Compose. Replace this placeholder before every deployment.
POSTGRES_PASSWORD=change-me-postgres-password
# Only used with docker-compose.local-debug.yml. The port remains loopback-only.
POSTGRES_PORT=5432

# Only used with docker-compose.local-debug.yml. The port remains loopback-only.
REDIS_PORT=6379
REELSHORT_RATE_LIMIT_STORE=redis
NGINX_PORT=80

REELSHORT_SITE_URL=https://www.reelshort.com
REELSHORT_SITE_ID=37
REELSHORT_REQUEST_TIMEOUT_SECONDS=10
# 单次上游响应体最大字节数，默认 5 MiB。
REELSHORT_MAX_RESPONSE_BYTES=5242880
# 单次上游请求允许的最大重定向次数。
REELSHORT_MAX_REDIRECTS=3
REELSHORT_NEXT_BUILD_ID=
REELSHORT_CATALOG_SEARCH_KEYWORDS=
REELSHORT_CATALOG_SEARCH_KEYWORDS_EN=
REELSHORT_CATALOG_SEARCH_KEYWORDS_ZH_TW=
REELSHORT_CATALOG_MAX_PAGES_PER_KEYWORD=3
REELSHORT_CATALOG_MAX_BOOKS=500
REELSHORT_CATALOG_REQUEST_WORKERS=8
REELSHORT_CONTENT_REFRESH_ENABLED=true
REELSHORT_CONTENT_REFRESH_INITIAL_DELAY=5m
REELSHORT_CONTENT_REFRESH_INTERVAL=6h
REELSHORT_CONTENT_REFRESH_SHELVES=recommend
REELSHORT_CONTENT_REFRESH_LOCALES=en,zh-TW
REELSHORT_CONTENT_VIDEO_FALLBACK_TTL=10m

# Required for production. Generate and set a BCrypt hash; no production fallback exists.
REELSHORT_ADMIN_USERNAME=admin
REELSHORT_ADMIN_PASSWORD_HASH=

REELSHORT_INTERNAL_SUPER_TOKEN=change-me-internal-user-registration-token
REELSHORT_SMS_CALLBACK_ENABLED=true
REELSHORT_SMS_CALLBACK_URL=https://account.hjj888.cc/api/v1/supplier/sms
REELSHORT_SMS_CALLBACK_API_KEY=change-me-account-manager-api-key
REELSHORT_SMS_CALLBACK_API_SECRET=change-me-account-manager-api-secret
REELSHORT_SMS_CALLBACK_TIMEOUT=5s
REELSHORT_PAYMENT_CALLBACK_SECRET=change-me-payment-callback-secret
REELSHORT_JPA_DDL_AUTO=validate
REELSHORT_FLYWAY_ENABLED=true
