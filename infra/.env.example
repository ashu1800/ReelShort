# Copy this file to infra/.env before running docker compose.
# Replace every production secret before deployment.

POSTGRES_DB=reelshort
POSTGRES_USER=reelshort
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432

REDIS_PORT=6379
REELSHORT_RATE_LIMIT_STORE=redis
NGINX_PORT=80

REELSHORT_SITE_URL=https://www.reelshort.com
REELSHORT_SITE_ID=37
REELSHORT_REQUEST_TIMEOUT_SECONDS=10
REELSHORT_NEXT_BUILD_ID=

# Leave blank for local development to use the backend default admin hash.
# Production must set a BCrypt hash here.
REELSHORT_ADMIN_USERNAME=admin
REELSHORT_ADMIN_PASSWORD_HASH=

REELSHORT_PAYMENT_CALLBACK_SECRET=change-me-payment-callback-secret
REELSHORT_JPA_DDL_AUTO=validate
REELSHORT_FLYWAY_ENABLED=true
